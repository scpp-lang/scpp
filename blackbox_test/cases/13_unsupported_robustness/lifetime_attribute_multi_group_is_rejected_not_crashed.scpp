// spec §6.2 [dcl.attr.scpp.lifetime]: cross-function named lifetime groups
// let a return value be tied to one specific parameter even when other
// parameters belong to different groups.
const int& get_x(const int& x [[scpp::lifetime(a)]], const int& y [[scpp::lifetime(b)]]) [[scpp::lifetime(a)]] {
    return x;
}

int main() {
    int a = 1;
    int b = 2;
    return get_x(a, b);
}
