// ch04 §4.2: "A class with a non-static data member of reference type
// (T&/const T&) has no move assignment operator at all -- exactly real
// C++'s own rule ([class.copy.assign])... (a reference cannot be
// re-seated by assignment)."
class RefHolder {
    public:
        virtual ~RefHolder() { return; }
public:
    RefHolder(int& r) : r{r} {
        return;
    }
private:
    int& r;
};

int main() {
    int a = 1;
    int b = 2;
    RefHolder x{a};
    RefHolder y{b};
    y = std::move(x);
    return 0;
}
