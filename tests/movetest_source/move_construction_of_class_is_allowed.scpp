// spec §6.4(2): `ClassName y(std::move(x));` -- the compiler-synthesized
// move constructor -- works for an ordinary class, marking `x` moved-out.
class Widget {
public:
    Widget() { return; }
    int val;
};
int main() {
    Widget x;
    x.val = 5;
    Widget y{std::move(x)};
    return y.val;
}
