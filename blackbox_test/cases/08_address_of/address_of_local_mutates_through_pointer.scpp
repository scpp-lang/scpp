// ch05 §5.7: "&expr evaluates to ... T* if it's reachable mutably" -- a
// plain mutable local produces a writable T*, and writing through it is
// visible via the original variable name.
int f() {
    int x = 1;
    int* p = &x;
    [[scpp::unsafe]] {
        *p = 9;
    }
    return x;
}

int main() {
    return f();
}
