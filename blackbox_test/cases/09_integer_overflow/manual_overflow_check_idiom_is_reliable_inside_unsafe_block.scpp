// ch05 §5.8: "Manual overflow detection becomes reliable inside
// [[scpp::unsafe]]: the classic if (x + 1 < x) idiom is unreliable for signed x in
// real C++ ... Since scpp never emits nsw, there is no such license to
// exploit, so this idiom works exactly as its arithmetic reads: x =
// INT_MAX wraps x + 1 to INT_MIN, and INT_MIN < INT_MAX is (correctly)
// true." Checking is unconditional by default now, so `x + 1` must be
// wrapped in [[scpp::unsafe]] { } to see it wrap instead of abort.
int main() {
    int x = 2147483647;
    int y = 0;
    [[scpp::unsafe]] {
        y = x + 1;
    }
    if (y < x) {
        return 1;
    }
    return 0;
}
