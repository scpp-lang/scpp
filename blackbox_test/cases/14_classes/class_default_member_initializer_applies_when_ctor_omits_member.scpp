// spec 6.1(2.1)/(4.2): an in-class default member initializer supplies the
// member value for a constructor that does not name that member itself.
class Counter {
private:
    int value{5};
public:
    Counter() {
        return;
    }
    int get() const {
        return this->value;
    }
};

int main() {
    Counter c{};
    return c.get() - 5;
}
