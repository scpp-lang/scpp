import std;
// Current `main` empirically rejects `std::move(p)` when `p` is a pointer
// local: `std::move` is still restricted to class-typed variables in this
// version. Revisit this case if the separate std::move genericity work lifts
// that implementation restriction.
int main() {
    int x = 7;
    int* p = &x;
    int* q = std::move(p);
    [[scpp::unsafe]] {
        return *q;
    }
}
