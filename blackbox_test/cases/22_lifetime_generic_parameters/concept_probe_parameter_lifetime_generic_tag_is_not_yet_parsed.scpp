// ch05 §5.13: "A requires-expression's own probe parameter may carry the
// same tag. Tagging a compound requirement's probe parameter
// [[scpp::lifetime(generic)]] changes what that requirement checks" --
// e.g. `requires(T a, Token& tok [[scpp::lifetime(generic)]]) { ... }`.
// This exact documented syntax is currently rejected at parse time
// ("expected ')' but found '['") -- a requires-expression's parameter
// list doesn't accept an attribute on a probe parameter at all yet,
// even though the same attribute is accepted fine on an ordinary
// function parameter (see
// lifetime_generic_tag_on_ordinary_parameter_is_accepted.scpp).
class Token {
public:
    int value{};
};

template<typename T>
concept AcceptsToken = requires(T a, Token& tok [[scpp::lifetime(generic)]]) {
    { a(tok) } -> std::same_as<void>;
};

int main() {
    return 0;
}
