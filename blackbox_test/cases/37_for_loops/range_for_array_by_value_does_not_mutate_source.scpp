// spec 8.3(6): a by-value range-for loop variable receives an element copy;
// assigning to it does not mutate the underlying array element.
int main() {
    int values[3];
    values[0] = 1;
    values[1] = 2;
    values[2] = 3;
    for (int value : values) {
        value = value + 10;
    }
    return values[0] + values[1] + values[2] - 6;
}
