import std;

class Resource {
    public:
        virtual ~Resource() { return; }
private:
    std::unique_ptr<int> p{};
public:
    Resource(int value) {
        this->p = std::make_unique<int>(value);
        return;
    }
};

void take_by_value(Resource resource) {
    return;
}

int main() {
    Resource resource{1};
    take_by_value(std::move(resource));
    return 0;
}
