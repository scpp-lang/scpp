// A by-value parameter of class type is rejected unconditionally in
// this version, regardless of whether the class type itself is
// copy-eligible per ch04 §4.2 -- this is a separate, still-standing
// restriction from copy/move construction and assignment (`Foo b = a;`/
// `b = a;`), not something ch04 §4.2's compiler-provided/user-defined
// copy rules relax. `Counter` here is additionally not copy-eligible at
// all (a user-declared destructor with no copy constructor/assignment
// of its own suppresses both, ch08 Q15). Pass `const Counter&`/
// `Counter&` instead.
class Counter {
private:
    int value;
public:
    Counter(int start) {
        this->value = start;
        return;
    }
    ~Counter() {
        return;
    }
};

void take_by_value(Counter c) {
    return;
}

int main() {
    Counter c(5);
    take_by_value(c);
    return 0;
}
