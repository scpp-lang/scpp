import std;
// Current `sizeof(expr)` semantics: the operand is unevaluated, so a
// `std::move(x)` inside it must not actually consume `x`.
int consume(std::unique_ptr<int> p) {
    return 0;
}

int main() {
    std::unique_ptr<int> p{};
    if (sizeof(std::move(p)) == 0) return 1;
    return consume(std::move(p));
}
