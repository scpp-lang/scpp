// spec §7.3 (9): the same partially untied chain becomes well-formed only
// once the enclosing arrow expression is wrapped in [[scpp::unsafe]].
struct Node {
    int value{};
};

struct Inner {
    Node* ptr{};

    Node* operator->() [[scpp::lifetime(self)]] {
        return this->ptr;
    }

    const Node* operator->() const [[scpp::lifetime(self)]] {
        return this->ptr;
    }
};

struct Outer {
    Node node{};
    Inner inner{};
    Outer(int value) {
        this->node.value = value;
        this->inner.ptr = &this->node;
    }

    Inner& operator->() {
        return this->inner;
    }

    const Inner& operator->() const {
        return this->inner;
    }
};

int main() {
    Outer outer{15};
    [[scpp::unsafe]] {
        return outer->value;
    }
}
