export module mathlib;

namespace mathlib {
    export int is_even(int x);
    int is_odd(int x);

    int is_even(int x) {
        if (x == 0) {
            return 1;
        }
        return is_odd(x - 1);
    }

    int is_odd(int x) {
        if (x == 0) {
            return 0;
        }
        return is_even(x - 1);
    }
}
