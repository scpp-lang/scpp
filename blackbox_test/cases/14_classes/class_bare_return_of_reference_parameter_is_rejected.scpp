import std;
// spec §6.7(2)-(4): a reference parameter is not itself a non-reference
// parameter object, so `return param;` stays ill-formed here.
class Counter {
private:
    std::unique_ptr<int> value{};
public:
    Counter(int start) {
        this->value = std::make_unique<int>(start);
        return;
    }
};

Counter echo(Counter& counter) {
    return counter;
}
