// spec §6.5(3): symmetric to copy_construction_compiler_provided_is_allowed.scpp
// -- a plain class also has an implicitly-defined copy assignment
// operator under the same conditions. `b = a;` (bare reassignment) is
// licensed.
class Widget {
    public:
        virtual ~Widget() { return; }
public:
    Widget() { return; }
    void operator=(const Widget& other) {
        this->val = other.val;
        return;
    }
    int val{};
};
int main() {
    Widget a{};
    Widget b{};
    b = a;
    return b.val;
}
