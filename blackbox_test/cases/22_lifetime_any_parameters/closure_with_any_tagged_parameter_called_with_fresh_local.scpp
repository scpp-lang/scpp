// ch05 §5.13: the overall "thread::scope-shaped" pattern this section
// targets -- a wrapper function invents a value internally (here,
// `tok`, a function-local `Token`) and calls a passed-in closure with a
// reference to it; the closure's own parameter is tagged
// `[[scpp::lifetime(any)]]`, matching how the spec's own example is
// written. The concept's own probe parameter is any-tagged too (see
// concept_probe_parameter_lifetime_any_tag_is_accepted.scpp), so per
// spec §6.2(22.3) this concept now genuinely requires an any-tagged
// candidate parameter, not just plain callability.
class Token {
    public:
        virtual ~Token() { return; }
public:
    int value{};
};

template<typename T>
concept AcceptsToken = requires(T a, Token& tok [[scpp::lifetime(any)]]) {
    { a(tok) } -> std::same_as<void>;
};

void with_fresh_token(AcceptsToken auto&& f) {
    Token tok{};
    tok.value = 42;
    f(tok);
    return;
}

int main() {
    int result = 0;
    with_fresh_token([&result](Token& t [[scpp::lifetime(any)]]) {
        result = t.value;
        return;
    });
    return result;
}
