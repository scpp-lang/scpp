// Ordinary non-`extern` forward declarations work at namespace scope too,
// not just at file scope: two later definitions can call each other before
// both bodies have appeared textually.
namespace parity {
    int is_even(int x);
    int is_odd(int x);

    int is_even(int x) {
        if (x == 0) {
            return 1;
        }
        return is_odd(x - 1);
    }

    int is_odd(int x) {
        if (x == 0) {
            return 0;
        }
        return is_even(x - 1);
    }
}

int main() {
    return parity::is_even(6) - 1;
}
