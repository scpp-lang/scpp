import std;
// spec 8.3(7)-(8): `auto&` over a mutable span binds the underlying element
// through a reborrow, so mutation flows back to the original array.
int main() {
    int values[3];
    values[0] = 1;
    values[1] = 2;
    values[2] = 3;
    std::span<int> s = values;
    for (auto& value : s) {
        value = value + 2;
    }
    return values[0] + values[1] + values[2] - 12;
}
