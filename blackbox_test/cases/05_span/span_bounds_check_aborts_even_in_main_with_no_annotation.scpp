// ch01 §1.1/ch08 Q13: checking is unconditional by default -- there is no
// more "native function" that's exempt. `main` here has no annotation at
// all (there is no annotation to give -- `safe` no longer exists), and an
// out-of-bounds `s[10]` must still abort, exactly as it would inside any
// other function.
int main() {
    int arr[3];
    std::span<int> s = arr;
    return s[10];
}
