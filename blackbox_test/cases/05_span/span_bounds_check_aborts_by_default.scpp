// ch03/ch08 Q1: "Subscript s[i] carries a runtime bounds check by
// default, calling abort() on failure." Checking is unconditional now --
// no annotation is needed to enable it.
int oob(std::span<int> s) {
    return s[10];
}

int main() {
    int arr[3];
    std::span<int> s = arr;
    return oob(s);
}
