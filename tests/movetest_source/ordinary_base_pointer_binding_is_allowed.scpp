class Base {
public:
    virtual ~Base() { return; }
    virtual int foo() const { return 1; }
};

class Derived : public Base {
public:
    ~Derived() override { return; }
    int foo() const override { return 2; }
};

int main() {
    Derived derived{};
    Base* base = &derived;
    return base == nullptr;
}
