// spec §8.1(3): non-generic ordinary calls must enforce
// `[[scpp::thread_movable]]` on non-interface parameters too.
class PlainHandle {
public:
    PlainHandle(int* raw) { this.raw = raw; return; }
    virtual ~PlainHandle() = default;
private:
    int* raw{};
};

void launch(PlainHandle value [[scpp::thread_movable]]) {
    return;
}

int main() {
    int value = 0;
    launch(PlainHandle{&value});
    return 0;
}
