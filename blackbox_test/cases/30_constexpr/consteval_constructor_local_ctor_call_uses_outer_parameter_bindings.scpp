class Helper {
public:
    virtual ~Helper() = default;
public:
    consteval Helper(const char* s, int i) { return; }
};

class Outer {
public:
    virtual ~Outer() = default;
public:
    consteval Outer(const char* s) {
        Helper h{s, 0};
        return;
    }
};

int main() {
    Outer o{"x"};
    return 0;
}
