class Adder {
private:
    int value;
public:
    Adder(int start) {
        this->value = start;
        return;
    }
    ~Adder() {
        return;
    }
    void add_ref(int& x) {
        this->value = this->value + x;
        return;
    }
    int get() const {
        return this->value;
    }
};
int f() {
    Adder a{5};
    int y = 3;
    a.add_ref(y);
    return a.get();
}
