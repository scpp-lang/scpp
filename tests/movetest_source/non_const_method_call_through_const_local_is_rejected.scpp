class Counter {
private:
    int value{};
public:
    Counter(int start) {
        this->value = start;
        return;
    }
    void bump() {
        this->value = this->value + 1;
        return;
    }
    int get() const {
        return this->value;
    }
};

int main() {
    const Counter c{0};
    c.bump();
    return c.get();
}
