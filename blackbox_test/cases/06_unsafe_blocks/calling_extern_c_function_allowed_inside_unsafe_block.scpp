// ch01 §1.3 / ch02: wrapping the call to an extern "C" function in
// `[[scpp::unsafe]] { }` is exactly the "programmer vouches for it" escape hatch.
extern "C" int abs(int x);

int caller() {
    int result = 0;
    [[scpp::unsafe]] {
        result = abs(-7);
    }
    return result;
}

int main() {
    return caller();
}
