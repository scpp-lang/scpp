class [[scpp::interface]] IRun {
public:
    virtual ~IRun() { return; }
    virtual void run() = 0;
};

class Runner : public virtual IRun {
public:
    ~Runner() override { return; }
    void run() override { return; }
};

int main() {
    Runner runner{};
    IRun* iface = &runner;
    [[scpp::unsafe]] {
        size_t bits = static_cast<size_t>(iface);
    }
    return 0;
}
