// The documented workaround for the by-value-parameter restriction
// (see class_by_value_parameter_is_rejected.scpp): pass by
// `const Counter&`/`Counter&` instead of by value.
class Counter {
private:
    int value{};
public:
    Counter(int start) {
        this->value = start;
        return;
    }
    ~Counter() {
        return;
    }
    int get() const {
        return this->value;
    }
};

int take_by_reference(const Counter& c) {
    return c.get();
}

int main() {
    Counter a{5};
    return take_by_reference(a);
}
