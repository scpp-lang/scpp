class Box {
    public:
        virtual ~Box() { return; }
private:
    int value{};

public:
    Box() {
        this->value = 7;
        return;
    }

    Box(const Box& other) {
        this->value = other.value;
        return;
    }

    void operator=(const Box& other) {
        this->value = other.value;
        return;
    }

    int first() const {
        return this->value;
    }
};

int main() {
    Box seed{};
    Box boxes[2];
    boxes[1] = seed;
    Box copy{boxes[1]};
    print_int(copy.first());
    return 0;
}
