// spec 6.1(3)-(4): a constructor member-initializer-list may initialize a
// member with braces before the function body runs.
class Counter {
    public:
        virtual ~Counter() { return; }
private:
    int value;
public:
    Counter(int start) : value{start} {
        return;
    }
    int get() const {
        return this->value;
    }
};

int main() {
    Counter c{7};
    return c.get() - 7;
}
