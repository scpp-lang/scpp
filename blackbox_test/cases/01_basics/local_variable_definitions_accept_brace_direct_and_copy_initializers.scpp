// spec 6.1(1)/(7): locals must have an initializer, and the valid local
// object-definition forms include `{}`, `{args}`, and `= value`.
class Counter {
private:
    int value{1};
public:
    Counter() {
        return;
    }
    Counter(int v) : value{v} {
        return;
    }
    int get() const {
        return this->value;
    }
};

Counter make_counter() {
    Counter c{9};
    return c;
}

int main() {
    int a{};
    int b{4};
    int c = 5;
    Counter x{};
    Counter y{7};
    Counter z = make_counter();
    return a + b + c + x.get() + y.get() + z.get() - 26;
}
