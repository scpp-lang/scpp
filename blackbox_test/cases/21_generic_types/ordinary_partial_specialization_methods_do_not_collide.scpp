template<typename Sig>
class Holder;

template<>
class Holder<void()> {
    public:
        virtual ~Holder() { return; }
public:
    int size() const { return 1; }
};

template<typename Head, typename... Tail>
class Holder<void(Head, Tail...)> {
    public:
        virtual ~Holder() { return; }
public:
    int size() const { return 2; }
};

int main() {
    Holder<void()> empty{};
    Holder<void(int)> unary{};
    return empty.size() + unary.size();
}
