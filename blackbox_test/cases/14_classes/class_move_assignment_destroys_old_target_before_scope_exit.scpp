import std;
// ch04 §4.2/spec §6.4(5): `b = std::move(a);` first destroys `b`'s old
// state, then overwrites it with `a`'s moved value; `a` itself is left in
// the moved-out state so only the newly-assigned `b` runs again at
// scope-exit. That means two destructor prints overall: once during the
// assignment for old `b`, once at scope-exit for new `b`, never for `a`.
extern "C" int printf(const char* fmt, ...);

class Resource {
public:
    Resource(int v) {
        this->p = std::make_unique<int>(v);
        return;
    }
    virtual ~Resource() {
        [[scpp::unsafe]] {
            printf("dtor\n");
        }
        return;
    }
    int get() {
        return *this->p;
    }
private:
    std::unique_ptr<int> p{};
};

int main() {
    Resource a{1};
    Resource b{2};
    b = std::move(a);
    return b.get();
}
