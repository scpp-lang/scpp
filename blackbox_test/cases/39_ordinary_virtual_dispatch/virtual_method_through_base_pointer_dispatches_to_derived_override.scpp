// Ordinary single-inheritance virtual dispatch through a base pointer must
// call the derived override.
class Base {
public:
    virtual ~Base() = default;
    virtual int value() {
        return 1;
    }
};

class Derived : public Base {
public:
    ~Derived() override = default;
    int value() override {
        return 9;
    }
};

int main() {
    Derived derived{};
    Base* base = &derived;
    [[scpp::unsafe]] {
        return base->value();
    }
}
