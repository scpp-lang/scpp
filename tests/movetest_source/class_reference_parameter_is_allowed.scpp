class Counter {
private:
    int value{};
public:
    Counter(int start) {
        this->value = start;
        return;
    }
    virtual ~Counter() {
        return;
    }
    int get() const {
        return this->value;
    }
};
int take_by_reference(const Counter& c) {
    return c.get();
}
int f() {
    Counter a{5};
    return take_by_reference(a);
}
