// docs/book/en/ch01-safety-context.md §1.1 and docs/spec/en/05-unions-and-packed-layout.md §9.1:
// union member access becomes legal inside [[scpp::unsafe]].
union IntOrChar {
    int number;
    char byte;
};

int main() {
    IntOrChar value;
    [[scpp::unsafe]] {
        value.number = 65;
        return static_cast<int>(value.byte);
    }
}
