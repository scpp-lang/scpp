import std;
// ch05 §5.18: moving a wrapper follows ordinary class move rules; the
// destination owns the callable target and remains invocable.
class Adder {
private:
    int delta{};
public:
    Adder(int n) {
        this->delta = n;
        return;
    }
    int call(int x) {
        return x + this->delta;
    }
};

int main() {
    std::move_only_function<int(int)> f{Adder(2)};
    std::move_only_function<int(int)> g{std::move(f)};
    return g.call(3);
}
