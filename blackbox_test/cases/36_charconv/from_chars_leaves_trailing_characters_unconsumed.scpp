import std;
// `std::from_chars` stops at the first non-digit, returns success, and leaves
// `ptr` at the first unconsumed character.
char read_char(const char* ptr) {
    [[scpp::unsafe]] {
        return *ptr;
    }
}

int main() {
    char text[6];
    text[0] = '4';
    text[1] = '2';
    text[2] = 'x';
    text[3] = 'y';
    text[4] = 'z';
    text[5] = '\0';
    const char* first = &text[0];
    const char* last = &text[5];
    int value = 0;
    std::from_chars_result result = std::from_chars(first, last, value);
    if (value != 42) return 1;
    if ((int)result.ec != 0) return 2;
    if (result.ptr == last) return 3;
    return read_char(result.ptr) == 'x' ? 0 : 4;
}
