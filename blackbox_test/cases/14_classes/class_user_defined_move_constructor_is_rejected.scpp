// User-declared move constructors are now allowed and resolve as a
// distinct overload from copy constructors.
class Widget {
public:
    Widget(int value) {
        this->val = value;
        return;
    }
    Widget(const Widget& other) {
        this->val = other.val + 100;
        return;
    }
    Widget() {
        this->val = 0;
        return;
    }
    Widget(Widget&& other) {
        this->val = other.val + 200;
        return;
    }
    int val;
};

int main() {
    Widget original(5);
    Widget copied(original);
    Widget moved(std::move(original));
    if (copied.val != 105) return 1;
    return moved.val;
}
