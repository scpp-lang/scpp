// ch01 §1.1: "Everything in §5.1-§5.4 ... runs unconditionally,
// everywhere, including inside an [[scpp::unsafe]] { } block. [[scpp::unsafe]] { } never
// disables this analysis." Two mutable borrows of the same place still
// conflict even when both borrows are taken inside an [[scpp::unsafe]] { } block --
// alias-XOR-mutability is never one of the things [[scpp::unsafe]] { } relaxes.
int f() {
    int x = 5;
    [[scpp::unsafe]] {
        int& r1 = x;
        int& r2 = x;
        return r1 + r2;
    }
}

int main() {
    return f();
}
