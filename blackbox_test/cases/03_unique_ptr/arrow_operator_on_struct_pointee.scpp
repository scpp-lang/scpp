import std;
// `std::unique_ptr<T>` explicitly provides operator->(), so `p->x`
// remains the safe end-to-end path for member access through the owned
// raw pointer.
struct Point {
    int x;
    int y;
};

int main() {
    std::unique_ptr<Point> p = std::make_unique<Point>();
    p->x = 3;
    p->y = 4;
    return p->x + p->y;
}
