// spec §6.2 [dcl.attr.scpp.lifetime](16) and (18.2): `generic` is
// reserved, denotes a fresh synthesized group per parameter, and cannot
// be named by a return annotation.
const int& bad_generic_return(
    const int& x [[scpp::lifetime(generic)]]
) [[scpp::lifetime(generic)]] {
    return x;
}

int main() {
    int x = 1;
    return bad_generic_return(x);
}
