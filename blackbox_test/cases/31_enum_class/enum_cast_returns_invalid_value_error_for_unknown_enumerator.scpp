import std;
import scpp;
// spec 14.1(5): `scpp::enum_cast<T>(value)` returns
// `scpp::enum_cast_error::invalid_value` for integers that name no enumerator.
enum class Color : uint8_t { red = 1, green = 2, blue = 7 };

int main() {
    auto color = scpp::enum_cast<Color>((uint8_t)9);
    if (color.has_value()) return 1;
    return color.error() == scpp::enum_cast_error::invalid_value ? 0 : 2;
}
