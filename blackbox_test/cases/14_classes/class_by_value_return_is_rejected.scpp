// Same still-standing restriction as the by-value-parameter case, for a
// return type instead of a parameter: returning a class type by value
// is rejected unconditionally in this version, independent of ch04
// §4.2's copy/move construction and assignment rules (which only
// license `Foo b = a;`/`b = a;`/`Foo b(std::move(a));`/`b =
// std::move(a);`, not an implicit move-or-copy-out-of a return
// statement).
class Counter {
private:
    int value;
public:
    Counter(int start) {
        this->value = start;
        return;
    }
    ~Counter() {
        return;
    }
};

Counter make_counter() {
    Counter c(5);
    return c;
}

int main() {
    return 0;
}
