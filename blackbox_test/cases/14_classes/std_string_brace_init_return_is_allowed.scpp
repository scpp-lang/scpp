import std;
// spec §6.6(3.3)/§6.7(3): a `return std::string{...};` operand is a fresh
// temporary of the exact return type and is therefore accepted.
std::string make_text() {
    return std::string{"brace"};
}

int main() {
    std::string text = make_text();
    if (!text.equals("brace")) {
        return 1;
    }
    return 0;
}
