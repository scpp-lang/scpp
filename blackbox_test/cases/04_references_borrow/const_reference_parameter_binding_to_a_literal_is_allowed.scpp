import std;
// ch03: "`T&`/`const T&` -- reuses real C++ reference syntax." Real C++
// allows a `const T&` parameter to bind directly to a temporary (a
// literal constant, or any other rvalue), extending the temporary's
// lifetime for the call -- a common, idiomatic pattern
// (`f(42)` for `void f(const int& x)`). Originally written as a known
// failure (a reference could only borrow a plain local variable, a
// field of one, an array element of one, a dereferenced
// std::unique_ptr/raw-pointer local, or the result of a call to a
// reference-returning function -- not an arbitrary expression, which
// included a bare literal) -- confirmed fixed on re-verification,
// renamed from
// `const_reference_parameter_binding_to_a_literal_is_not_yet_supported.scpp`
// to match. Passing a named local variable instead also still works
// fine (see writing_through_const_reference_parameter_is_rejected.scpp
// and others in this category).
int f(const int& x) {
    int y = x;
    return y;
}

int main() {
    return f(42);
}
