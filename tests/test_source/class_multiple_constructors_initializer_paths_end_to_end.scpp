class Multi {
    public:
        virtual ~Multi() { return; }
    int x{};
    int y = 3;
public:
    Multi() { return; }
    Multi(int value) : x{value}, y{value + 1} { return; }
    int sum() { return this->x + this->y; }
};

int main() {
    Multi a{};
    Multi b{4};
    return a.sum() + b.sum() - 12;
}
