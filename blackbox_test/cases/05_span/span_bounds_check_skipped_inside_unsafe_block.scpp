// ch01 §1.1: the bounds check is one of only two things `unsafe { }`
// relaxes for a "runtime check" reason (alongside integer overflow) --
// here only the access itself is wrapped, proving the block's effect is
// purely lexical/local, not a whole-function switch.
int oob(std::span<int> s) {
    unsafe {
        return s[10];
    }
}

int main() {
    int arr[3];
    std::span<int> s = arr;
    return oob(s);
}
