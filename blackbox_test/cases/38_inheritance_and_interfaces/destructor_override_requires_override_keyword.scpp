// spec §11.5(5),(7): destructors overriding a virtual base destructor must
// also spell `override`.
class [[scpp::interface]] IRunner {
public:
    virtual ~IRunner() = default;
    virtual void run() = 0;
};

class Runner : public virtual IRunner {
public:
    virtual ~Runner() = default;

    void run() override {
        return;
    }
};

int main() {
    return 0;
}
