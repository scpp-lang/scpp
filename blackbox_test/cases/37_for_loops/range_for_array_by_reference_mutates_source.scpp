// spec 8.3(7): an `auto&` range-for loop variable aliases the underlying
// array element, so writes through it mutate the array.
int main() {
    int values[3];
    values[0] = 1;
    values[1] = 2;
    values[2] = 3;
    for (auto& value : values) {
        value = value + 1;
    }
    return values[0] + values[1] + values[2] - 9;
}
