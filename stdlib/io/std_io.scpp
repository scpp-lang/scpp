// std_io.scpp
//
// The `:io` interface partition of the "std" module: a small, safe printing
// surface for teaching examples (`std::print`, `std::println`, and
// `std::format_string`). v1 intentionally supports only bare `{}`
// placeholders plus escaped `{{` / `}}`, with runtime validation of placeholder
// count. It does *not* yet implement C++23's typed `format_string<Args...>`
// or consteval compile-time checking; those gaps are explicit rather than
// silently pretending full parity. The current surface provides exact
// overloads for 0-3 arguments.
export module std:io;

export import :string;

extern "C" {
    void* scpp_format_args_new();
    void scpp_format_args_delete(void* handle);
    void scpp_format_args_push_int(void* handle, int value);
    void scpp_format_args_push_bool(void* handle, bool value);
    void scpp_format_args_push_char(void* handle, char value);
    void scpp_format_args_push_double(void* handle, double value);
    void scpp_format_args_push_cstring(void* handle, const char* value);
    void scpp_format_write(void* handle, const char* fmt, bool append_newline);
    void scpp_format_write_empty_line();
}

namespace std {

export class format_string {
private:
    const char* text_;

public:
    format_string(const char* text) {
        this->text_ = text;
        return;
    }

    const char* c_str() const {
        return this->text_;
    }
};

void* __format_new_handle() {
    [[scpp::unsafe]] { return scpp_format_args_new(); }
}

void __format_finish(void* handle, const char* fmt, bool append_newline) {
    [[scpp::unsafe]] {
        scpp_format_write(handle, fmt, append_newline);
        scpp_format_args_delete(handle);
    }
    return;
}

export void println() {
    [[scpp::unsafe]] { scpp_format_write_empty_line(); }
    return;
}

export void print(const char* fmt) {
    void* handle = __format_new_handle();
    __format_finish(handle, fmt, false);
    return;
}

export void print(const char* fmt, int a1) {
    void* handle = __format_new_handle();
    [[scpp::unsafe]] {
        scpp_format_args_push_int(handle, a1);
    }
    __format_finish(handle, fmt, false);
    return;
}

export void print(const char* fmt, bool a1) {
    void* handle = __format_new_handle();
    [[scpp::unsafe]] {
        scpp_format_args_push_bool(handle, a1);
    }
    __format_finish(handle, fmt, false);
