// ch04 §4.2 / ch08 Q15: `Counter` declares a destructor and nothing
// else copy-related, so it gets *neither* a compiler-provided copy
// constructor nor a compiler-provided copy assignment operator (no
// "mixed" state where one is silently auto-generated) -- and since it
// declares no copy assignment operator of its own either, `a = b;`
// (bare reassignment) has no copy assignment operator to call at all.
class Counter {
private:
    int value{};
public:
    Counter(int start) {
        this->value = start;
        return;
    }
    virtual ~Counter() {
        return;
    }
};

int main() {
    Counter a{5};
    Counter b{9};
    a = b;
    return 0;
}
