// A mutable reference to a struct lets the callee mutate one of the
// caller's fields, visible after the call returns.
struct Point {
    int x;
    int y;
};

void bump_x(Point& p) {
    p.x = p.x + 100;
    return;
}

int main() {
    Point p;
    p.x = 1;
    p.y = 2;
    bump_x(p);
    return p.x + p.y;
}
