template<typename Sig>
class Holder;

template<typename R, typename... Args>
class Holder<R(Args...)> {
public:
    R (*fn_)(Args...){};

    R call(Args... args) {
        return this.fn_(args...);
    }
};

int add(int a, int b) { return a + b; }

int main() {
    Holder<int(int, int)> h{};
    h.fn_ = add;
    return h.call(2, 3) - 5;
}
