// Real-C++ namespace lookup: one class in a namespace may refer to
// another class in that same namespace by its unqualified name.
namespace demo {
class Helper {
    public:
        virtual ~Helper() { return; }
public:
    int value{};
};

class Holder {
    public:
        virtual ~Holder() { return; }
public:
    Helper helper{};
    int read() {
        return this->helper.value;
    }
};
}

int main() {
    demo::Holder h{};
    h.helper.value = 6;
    return h.read();
}
