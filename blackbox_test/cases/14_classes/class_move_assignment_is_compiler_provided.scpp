// ch04 §4.2/ch08 Q14: symmetric to
// class_move_construction_is_compiler_provided.scpp -- every class gets
// a compiler-synthesized move assignment operator unconditionally, even
// `Counter` (not copy-eligible at all, ch08 Q15).
class Counter {
private:
    int value;
public:
    Counter(int start) {
        this->value = start;
        return;
    }
    ~Counter() {
        return;
    }
    int get() const {
        return this->value;
    }
};

int main() {
    Counter x(5);
    Counter y(9);
    y = std::move(x);
    return y.get();
}
