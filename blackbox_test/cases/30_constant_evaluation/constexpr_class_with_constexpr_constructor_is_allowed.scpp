// spec §7.2(2) and §9.1(3)/(6): a class whose fields are
// constexpr-compatible may participate in required constant evaluation
// when construction goes through a `constexpr` constructor.
class Point {
public:
    int x;
    int y;

    constexpr Point(int x, int y) {
        this->x = x;
        this->y = y;
        return;
    }

    int sum() const {
        return this->x + this->y;
    }
};

int main() {
    constexpr Point p{19, 23};
    return p.sum();
}
