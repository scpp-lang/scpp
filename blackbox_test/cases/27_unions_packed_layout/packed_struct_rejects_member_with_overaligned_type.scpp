// docs/spec/en/05-unions-and-packed-layout.md §9.3:
// a packed struct cannot contain a non-static data member whose class type is
// itself over-aligned by alignas.
struct alignas(8) Block8 {
    int value;
};

struct [[scpp::packed]] Packet {
    char tag;
    Block8 payload;
};

int main() {
    return sizeof(Packet);
}
