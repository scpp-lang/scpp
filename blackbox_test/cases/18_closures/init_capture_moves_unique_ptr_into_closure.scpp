import std;
// ch05 §5.12: "Init-capture is how a move-only type crosses into a
// closure, exactly like passing one to a constructor:
// `[p = std::move(p)]` for a `std::unique_ptr<T> p`." Called immediately
// (IIFE), so no name is needed for the closure itself.
int main() {
    std::unique_ptr<int> p = std::make_unique<int>(7);
    return [p = std::move(p)]() { return *p; }();
}
