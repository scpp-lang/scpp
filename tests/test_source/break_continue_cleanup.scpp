class Guard {
public:
    int id_;

    Guard(int id) {
        this->id_ = id;
        return;
    }

    ~Guard() {
        print_int(this->id_);
        return;
    }
};

int main() {
    int i = 0;
    while (i < 4) {
        Guard g(i);
        if (i == 1) {
            i = i + 1;
            continue;
        }
        if (i == 3) {
            break;
        }
        print_int(i);
        i = i + 1;
    }
    return 0;
}
