import std;
// Current `scpp::storage_for<T, U, ...>` semantics: user-defined candidate
// types participate in the same max-size/max-alignment computation.
class Widget {
    public:
        virtual ~Widget() { return; }
public:
    char c{};
    long value{};
};

struct Wrapper {
    char lead;
    scpp::storage_for<Widget, int> storage;
};

int main() {
    if (sizeof(scpp::storage_for<Widget, int>) != 16) return 1;
    if (sizeof(Wrapper) != 24) return 2;
    return 0;
}
