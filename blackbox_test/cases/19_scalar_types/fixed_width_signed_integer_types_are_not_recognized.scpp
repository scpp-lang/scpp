// ch06 scalar table: `int8_t`/`int16_t`/`int32_t`/`int64_t` "reuse real
// C++ `<cstdint>` names verbatim, all already-standardized... scpp
// guarantees all of these unconditionally on every target." These are
// core builtin scalar types, not a backlog item -- but none of the four
// are currently recognized as a type name at all (rejected with "expected
// a type name" / "expected ';' but found ..."), even though `int` and
// `char` (also core scalars) work fine.
int8_t identity8(int8_t x) {
    return x;
}

int16_t identity16(int16_t x) {
    return x;
}

int32_t identity32(int32_t x) {
    return x;
}

int64_t identity64(int64_t x) {
    return x;
}

int main() {
    int8_t a = 1;
    int16_t b = 2;
    int32_t c = 3;
    int64_t d = 4;
    return 0;
}
