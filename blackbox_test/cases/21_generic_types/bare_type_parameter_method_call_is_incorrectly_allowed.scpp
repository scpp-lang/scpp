// ch05 §5.14: a bare (unconstrained) generic type parameter means "it is
// not enough to call any method on the type or apply any operator to
// it" -- calling a method on a bare-`T`-typed field should be a compile
// error at the generic type's own definition, regardless of what any
// particular instantiation (like `Num`, which does have a `doubled()`
// method) would allow. Currently this is accepted instead -- no error
// at `Holder`'s own definition even though `T` is completely
// unconstrained there, contradicting the once-at-definition checking
// principle §5.11/§5.14 both establish.
class Num {
public:
    int v;
    int doubled() {
        return this->v + this->v;
    }
};

template<typename T>
class Holder {
    T item;
public:
    Holder(const T& x) {
        this->item = x;
        return;
    }
    int bad() {
        return this->item.doubled();
    }
};

int main() {
    Num a;
    a.v = 21;
    Holder<Num> h(a);
    return h.bad();
}
