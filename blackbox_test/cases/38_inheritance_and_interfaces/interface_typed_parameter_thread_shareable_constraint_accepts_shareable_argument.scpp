// spec §8.5(6): the reference-to-interface parameter constraint accepts a
// concrete argument type whose own property is thread-shareable.
class [[scpp::interface]] IView {
public:
    virtual ~IView() = default;
    virtual int render() const = 0;
};

class GoodView : public virtual IView {
private:
    int value{};
public:
    GoodView(int value_) : value{value_} {
        return;
    }

    ~GoodView() override = default;

    int render() const override {
        return this->value;
    }
};

int publish(IView& view [[scpp::thread_shareable]]) {
    return 4;
}

int main() {
    GoodView good{4};
    return publish(good);
}
