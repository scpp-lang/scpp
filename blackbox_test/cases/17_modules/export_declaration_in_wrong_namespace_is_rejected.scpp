// ch11 §11.6: "An export on a declaration anywhere else (wrong namespace,
// or no enclosing namespace at all) is a compile error." `helper` is
// exported from inside `namespace bar`, but the module is named `foo` --
// the namespace doesn't match the module's own dotted name.
export module foo;

namespace bar {
    export int helper() {
        return 5;
    }
}

int main() {
    return 0;
}
