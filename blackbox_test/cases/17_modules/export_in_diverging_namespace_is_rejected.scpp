// Counterpart to the "nested deeper is allowed" case: a namespace that
// diverges from the module's dotted name (rather than nesting further
// inside it) still doesn't satisfy the prefix requirement.
// `org::lotx::other` does not start with the required `org::lotx::cmath`
// prefix.
export module org.lotx.cmath;

namespace org::lotx::other {
    export int helper() {
        return 1;
    }
}

int main() {
    return 0;
}
