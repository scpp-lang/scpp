import std;
// Current `std::expected<T, E>` semantics: calling `.value()` while the
// object holds an error is a hard abort, not recoverable undefined behavior.
enum class calc_error { invalid };

int main() {
    std::unexpected<calc_error> err{calc_error::invalid};
    std::expected<int, calc_error> bad{err};
    return bad.value();
}
