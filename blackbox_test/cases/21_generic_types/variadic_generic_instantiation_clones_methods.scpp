template<typename... Ts>
class Box;

template<>
class Box<> {
    public:
        virtual ~Box() { return; }
public:
    int size() const { return 10; }
};

template<typename Head, typename... Tail>
class Box<Head, Tail...> : private Box<Tail...> {
    public:
        virtual ~Box() override { return; }
public:
    int size() const { return 50; }
};

int main() {
    Box<int, bool> b{};
    return b.size() - 50;
}
